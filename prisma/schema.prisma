generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              String                 @id @default(cuid())
  name            String
  description     String?
  price           Decimal                @db.Decimal(10, 2)
  imageUrl        String?
  available       Boolean                @default(true)
  type            ProductType            @default(FINAL)
  selectionTitle  String?
  order           Int                    @default(0)
  category        Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId      String
  customizations  ProductCustomization[]
  parentRelations ProductRelation[]      @relation("ProductRelationParent")
  childRelations  ProductRelation[]      @relation("ProductRelationChild")
  optionInGroups  CustomizationOption[]  @relation("CustomizationOptionProduct")
  orderItems      OrderItem[]
  createdAt       DateTime               @default(now())
}

model ProductRelation {
  id              String   @id @default(cuid())
  parent          Product  @relation("ProductRelationParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  parentProductId String
  child           Product  @relation("ProductRelationChild", fields: [childProductId], references: [id], onDelete: Cascade)
  childProductId  String
  isPaid          Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([parentProductId, childProductId])
  @@index([parentProductId])
  @@index([childProductId])
}

model ProductCustomization {
  id        String                @id @default(cuid())
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  label     String
  required  Boolean               @default(false)
  minSelect Int                   @default(0)
  maxSelect Int?
  affectsPrice Boolean            @default(true)
  freeQuantity Int                @default(0)
  options   CustomizationOption[]
}

model CustomizationOption {
  id              String               @id @default(cuid())
  customization   ProductCustomization @relation(fields: [customizationId], references: [id], onDelete: Cascade)
  customizationId String
  optionProduct   Product?             @relation("CustomizationOptionProduct", fields: [optionProductId], references: [id], onDelete: SetNull)
  optionProductId String?
  name            String
  priceModifier   Decimal              @default(0) @db.Decimal(10, 2)
}

enum ProductType {
  FINAL
  COMPOSED
  ACCOMPANIMENT
}

model Table {
  id     String  @id @default(cuid())
  number Int     @unique
  code   String  @unique
  active Boolean @default(true)
  orders Order[]
}

model Order {
  id            String        @id @default(cuid())
  status        OrderStatus   @default(PENDING)
  type          OrderType
  paymentMethod PaymentMethod
  changeFor     Decimal?      @db.Decimal(10, 2)
  pixProvider   String?
  table         Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableId       String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  address       String?
  notes         String?
  total         Decimal       @db.Decimal(10, 2)
  items         OrderItem[]
  externalRefs  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  notes     String?
  choices   Json
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderType {
  TABLE
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  PIX
}
