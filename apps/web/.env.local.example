# Copie para apps/web/.env.local (Next.js carrega daqui no `nx dev web`).
# Use os mesmos valores do painel Supabase → Connect → ORM: Prisma.

# Pool transação (serverless / PgBouncer) — porta 6543
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Opção A — migrações / introspection: host direto db.* na 5432
# DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# Opção B (guia Supabase) — mesma pooler, porta 5432 (session) para DIRECT_URL:
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
