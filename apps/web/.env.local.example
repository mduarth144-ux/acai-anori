# Copie para apps/web/.env.local (Next.js carrega daqui no `nx dev web`).
# Use os mesmos valores do painel Supabase → Connect → ORM: Prisma.

# Transação (Vercel) — copiar host exato do Connect (ex.: aws-1-us-west-2.pooler.supabase.com)
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Sessão (migrate) — mesma pooler, porta 5432
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
