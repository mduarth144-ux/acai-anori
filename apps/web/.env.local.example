# Copie para apps/web/.env.local (Next.js carrega daqui no `npm run dev`).
# Use os mesmos valores do painel Supabase → Connect → ORM: Prisma.

# Transação (Vercel) — copiar host exato do Connect (ex.: aws-1-us-west-2.pooler.supabase.com)
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Sessão (migrate) — mesma pooler, porta 5432
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# iFood (server-side)
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_MERCHANT_ID=
IFOOD_WEBHOOK_SECRET=
# Minimo 16 caracteres; usado para emitir token de "confirmar recebimento" no link do pedido (somente entrega).
CUSTOMER_ORDER_ACTION_SECRET=
IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_AUTH_URL=https://merchant-api.ifood.com.br/authentication/v1.0/oauth/token
IFOOD_SHIPPING_ENABLED=true
IFOOD_SHIPPING_QUOTE_PATH=/shipping/v1.0/quotes
IFOOD_SHIPPING_ORDER_PATH=/shipping/v1.0/merchants/{merchantId}/orders
IFOOD_PICKUP_ADDRESS=

# Integração Order API + fluxo Super Integradoras (opcional)
# Se false (default), mantém apenas Shipping/coverage como antes — sem POST /order/v1.0/orders na criação.
IFOOD_ORDER_API_ON_CREATE=false
# confirm / startPreparation / readyToPickup / dispatch em vez de só POST .../status
IFOOD_ORDER_USE_DEDICATED_ENDPOINTS=true
# Motivo de cancelamento quando a API não lista opções (merchant-initiated)
IFOOD_DEFAULT_CANCEL_CODE=
# Polling de eventos (cron recomendado a cada 30s → POST /api/integrations/ifood/events-poll com x-job-secret)
IFOOD_EVENTS_POLLING_ENABLED=false
IFOOD_EVENTS_POLLING_CATEGORIES=FOOD,GROCERY

# Jobs internos (outbox, polling, tracking)
# INTERNAL_JOB_SECRET=
# CRON_SECRET=
