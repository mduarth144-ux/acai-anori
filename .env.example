NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: apenas em rotas servidor / jobs (nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma + Supabase — copiar strings em Connect (Prisma). Na Vercel use o host pooler (IPv4), não só db.*:5432.
# DATABASE_URL = transação, porta 6543, user postgres.<project-ref> (não só "postgres").
DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

# DIRECT_URL = sessão pooler :5432 (migrações) — mesmo user e região que no Connect.
DIRECT_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Alternativa só com IPv6 / máquina persistente: host direto db.* na 5432 (não ideal para serverless).
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Next (`nx dev web`): replique DATABASE_URL e DIRECT_URL em apps/web/.env.local — veja apps/web/.env.local.example

NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_PROJECT_ID=

# Opcional: seed busca previewURL na API Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=
