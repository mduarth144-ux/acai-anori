NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: apenas em rotas servidor / jobs (nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma + Supabase — copiar de Connect → pooling (o painel pode usar aws-0-* ou aws-1-* conforme a região).
# DATABASE_URL = transação :6543 + ?pgbouncer=true | DIRECT_URL = sessão :5432 | user = postgres.<project-ref>
DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

DIRECT_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# Alternativa só com IPv6 / máquina persistente: host direto db.* na 5432 (não ideal para serverless).
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Next (`npm run dev`): replique DATABASE_URL e DIRECT_URL em apps/web/.env.local — veja apps/web/.env.local.example

NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_PROJECT_ID=

# Opcional: seed busca previewURL na API Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=

# iFood
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_MERCHANT_ID=
IFOOD_WEBHOOK_SECRET=
IFOOD_API_BASE_URL=https://merchant-api.ifood.com.br
IFOOD_AUTH_URL=https://merchant-api.ifood.com.br/authentication/v1.0/oauth/token
IFOOD_SHIPPING_ENABLED=true
IFOOD_SHIPPING_QUOTE_PATH=/shipping/v1.0/quotes
IFOOD_SHIPPING_ORDER_PATH=/shipping/v1.0/merchants/{merchantId}/orders
# Endereco do ponto de retirada (origem da entrega)
IFOOD_PICKUP_ADDRESS=
