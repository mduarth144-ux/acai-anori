NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: apenas em rotas servidor / jobs (nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma + Supabase (copie do painel Connect → ORM: Prisma).
# DATABASE_URL = pool transação (6543 + pgbouncer) — runtime em serverless/Vercel.
DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# DIRECT_URL = para migrate/db push (escolha A ou B; comente a outra).
# A) Host direto db.*:5432
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
# B) Pooler sessão :5432 (alguns guias Supabase + Prisma)
# DIRECT_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Next (`nx dev web`): replique DATABASE_URL e DIRECT_URL em apps/web/.env.local — veja apps/web/.env.local.example

NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_PROJECT_ID=

# Opcional: seed busca previewURL na API Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=
