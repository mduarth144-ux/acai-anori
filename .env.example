NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: apenas em rotas servidor / jobs (nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma: na Vercel (IPv4) prefira Session ou Transaction pooler do Supabase
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres

NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_PROJECT_ID=

# Opcional: seed busca previewURL na API Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=
